<!-- index.html -->
<!-- Universitas Presentasi Project Smart Home IoT -->
<!-- Dirancang menggunakan HTML5 murni, CSS Modern, dan Modular JS SDK -->

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Home IoT - Panel Kontrol & Monitoring</title>
  
  <!-- Import Google Fonts (Inter & JetBrains Mono) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  
  <!-- Hubungkan ke File Style CSS Kustom -->
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Kontainer App dengan Cybernetic Grid Background -->
  <div class="app-container">
    
    <!-- Bagian Header Aplikasi -->
    <header>
      <div class="brand">
        <h1><span>⚡</span> SMART HOME IoT</h1>
        <p>CONTROL panel &bull; CAMPUS METEOROLOGY</p>
      </div>
      
      <!-- Jam Digital dan Indikator Status koneksi Firebase -->
      <div class="status-bar">
        <div class="clock" id="clock-time">00:00:00 WIB</div>
        <div class="network-status">
          <span class="dot" id="connection-dot"></span>
          <span id="connection-text">MENGHUBUNGKAN...</span>
        </div>
      </div>
    </header>

    <!-- Konten Dashboard Utama (Bento Layout) -->
    <main class="dashboard-grid">
      
      <!-- CARD 1: PEMBACAAN SENSOR (DHT11) -->
      <section class="card">
        <h2 class="card-title">
          <span>🌡️</span> MONITORING TELEMETRI SENSOR dht11
        </h2>
        <div class="sensor-row">
          <!-- Pembacaan Suhu -->
          <div class="sensor-gauge" id="card-temp">
            <div class="sensor-icon">🔥</div>
            <div class="sensor-value" id="temp-value">--°C</div>
            <div class="sensor-label">Suhu DHT11</div>
          </div>
          <!-- Pembacaan Kelembaban -->
          <div class="sensor-gauge" id="card-humidity">
            <div class="sensor-icon">💧</div>
            <div class="sensor-value" id="hum-value">--%</div>
            <div class="sensor-label">Kelembaban</div>
          </div>
        </div>
      </section>

      <!-- CARD 2: KONTROL RELE / SAKLAR LAMPU -->
      <section class="card">
        <h2 class="card-title">
          <span>💡</span> SISTEM KONTROL RELAY LAMPU
        </h2>
        <div class="relay-list">
          
          <!-- Relay 1 -->
          <div class="relay-item" id="relay-card-1">
            <div class="relay-info">
              <span class="relay-bulb" id="bulb-1">💡</span>
              <div class="relay-details">
                <h4>Relay Lampu Utama 1</h4>
                <p class="relay-badge" id="relay-status-1">OFF</p>
              </div>
            </div>
            <div class="relay-actions">
              <button class="btn btn-on" id="btn-on-1">ON</button>
              <button class="btn btn-off" id="btn-off-1">OFF</button>
            </div>
          </div>

          <!-- Relay 2 -->
          <div class="relay-item" id="relay-card-2">
            <div class="relay-info">
              <span class="relay-bulb" id="bulb-2">💡</span>
              <div class="relay-details">
                <h4>Relay Lampu Kamar 2</h4>
                <p class="relay-badge" id="relay-status-2">OFF</p>
              </div>
            </div>
            <div class="relay-actions">
              <button class="btn btn-on" id="btn-on-2">ON</button>
              <button class="btn btn-off" id="btn-off-2">OFF</button>
            </div>
          </div>

          <!-- Relay 3 -->
          <div class="relay-item" id="relay-card-3">
            <div class="relay-info">
              <span class="relay-bulb" id="bulb-3">💡</span>
              <div class="relay-details">
                <h4>Relay Lampu Dapur 3</h4>
                <p class="relay-badge" id="relay-status-3">OFF</p>
              </div>
            </div>
            <div class="relay-actions">
              <button class="btn btn-on" id="btn-on-3">ON</button>
              <button class="btn btn-off" id="btn-off-3">OFF</button>
            </div>
          </div>

          <!-- Relay 4 -->
          <div class="relay-item" id="relay-card-4">
            <div class="relay-info">
              <span class="relay-bulb" id="bulb-4">💡</span>
              <div class="relay-details">
                <h4>Relay Air Conditioner 4</h4>
                <p class="relay-badge" id="relay-status-4">OFF</p>
              </div>
            </div>
            <div class="relay-actions">
              <button class="btn btn-on" id="btn-on-4">ON</button>
              <button class="btn btn-off" id="btn-off-4">OFF</button>
            </div>
          </div>

        </div>
      </section>

      <!-- CARD 3: ASISTEN SUARA (VOICE COMMAND) -->
      <section class="card">
        <h2 class="card-title">
          <span>🎤</span> KONTROL SUARA JARINGAN (ID)
        </h2>
        <div class="voice-container">
          <button class="voice-mic-btn" id="mic-btn" title="Klik untuk berbicara">
            🎙️
          </button>
          <div class="speech-result-box">
            <p id="speech-text" class="speech-result-placeholder">
              Klik ikon mikrofon di atas lalu ucapkan "Nyalakan lampu 1"
            </p>
          </div>
          <p style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.5rem; line-height: 1.3;">
            Mendukung: "Nyalakan/matikan lampu [1-4]", "Nyalakan/matikan semua lampu" menggunakan Web Speech API.
          </p>
        </div>
      </section>

      <!-- CARD 4: TERMINAL LOG KEGIATAN AKTIF -->
      <section class="card" style="grid-column: 1 / -1;">
        <h2 class="card-title">
          <span>🖥️</span> TERMINAL LOG AKTIFITAS SISTEM (DEBUG)
        </h2>
        <div class="terminal">
          <div class="terminal-header">
            <span>SMART_HOME_DEBUGGER_v1.0</span>
            <span>LEVEL: SYSTEM VERIFICATION</span>
          </div>
          <div id="terminal-body">
            <!-- Isi logs akan diisi secara dinamis menggunakan JS -->
          </div>
        </div>
      </section>

    </main>

    <!-- POPUP NOTIFIKASI TOAST -->
    <div class="toast-notif" id="toast-notif">
      <span style="font-size: 1.25rem;">🔔</span>
      <span id="toast-msg">Notifikasi Baru</span>
    </div>

  </div>

  <!-- SCRIPT LOGIKA HUBUNGAN (Tipe Module untuk ES6 Modern) -->
  <script type="module" src="script.js"></script>
</body>
</html>
